{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2/crates/tauri-cli/schema.json",
  "productName": "MindMapVault",
  "version": "0.1.3-oss",
  "identifier": "com.mindmapvault.desktop",
  "build": {
    "frontendDist": "../../frontend_app/dist",
    "devUrl": "http://127.0.0.1:5274",
    "beforeDevCommand": "pnpm dev:app",
    "beforeBuildCommand": "npm run build --prefix ../frontend_app"
  },
  "app": {
    "windows": [
      {
        "title": "MindMapVault — Encrypted Mind Maps",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "useHttpsScheme": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage"],
    "publisher": "MindMapVault",
    "copyright": "© 2026 MindMapVault",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
